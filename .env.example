# AWS Credentials for Amazon Selling Partner API
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Flipkart API Credentials
FLIPKART_CLIENT_ID=your_flipkart_client_id
FLIPKART_CLIENT_SECRET=your_flipkart_client_secret

# Meta (Facebook) Ads API Credentials
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT_ID=your_meta_ad_account_id
